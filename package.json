{
  "name": "caya-pcb-studio",
  "productName": "CaYa PCB Studio",
  "version": "1.0.1",
  "description": "Kapsamlı çift katmanlı devre kartı (PCB) tasarım uygulaması — macOS, Windows & Web",
  "author": "CaYaDev (https://cayadev.com)",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dist": "vite build && electron-builder --publish never",
    "dist:win": "vite build && electron-builder --win --publish never",
    "dist:mac": "vite build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.caya.pcbstudio",
    "productName": "CaYa PCB Studio",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "afterSign": "scripts/afterSignMac.cjs"
  }
}
